# ============================================
# NovaRisk ESG - Environment Configuration Example
# ============================================
# Copy this file to .env and fill in with your actual values

# ---- Backend Server ----
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# ---- Database (PostgreSQL) ----
# Format: postgresql+psycopg2://username:password@host:port/database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/novarisk

# ---- Cache (Redis) ----
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=86400

# ---- Authentication ----
# JWT secret for token signing (use a strong random string in production)
API_AUTH_SECRET=your-secret-key-here
API_TOKEN_TTL_SECONDS=28800
DASHBOARD_USERNAME=investor
DASHBOARD_PASSWORD=your-secure-password

# ---- Frontend ----
VITE_API_URL=http://localhost:8000/api/v1
VITE_MAP_CENTER_LAT=0
VITE_MAP_CENTER_LON=0
VITE_MAP_ZOOM_LEVEL=3

# ---- STAC/Satellite Data API ----
# Microsoft Planetary Computer STAC endpoints
STAC_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1
STAC_SEARCH_TIMEOUT=300
STAC_MAX_ITEMS=100

# ---- Rasterio/Data Processing ----
RASTERIO_ENV_VSI_CURL_ALLOWED_RANGES=GET,HEAD
RASTERIO_GDAL_DISABLE_READDIR_ON_OPEN=YES
GDAL_HTTP_TIMEOUT=60

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Performance ----
CACHE_ENABLED=True
PARALLEL_DOWNLOADS=4
REQUEST_TIMEOUT=300

# ---- Report Generation ----
REPORT_DPI=300
REPORT_PAGE_SIZE=A4
TEMP_FILES_DIR=./tmp
