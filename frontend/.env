# Frontend Environment Configuration
# Vite uses VITE_ prefix for environment variables that are exposed to the browser

# Backend API URL - Where the FastAPI backend is running
# For local development: http://127.0.0.1:8000
# For Docker: http://backend:8000 or http://localhost:8000 depending on setup
VITE_API_URL=http://127.0.0.1:8000

# Application environment
# Can be: development, staging, production
VITE_ENVIRONMENT=development

# API timeout in milliseconds
VITE_API_TIMEOUT=60000
