# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# CORS Configuration - Frontend URLs allowed to access this API
# For local development: http://localhost:5173 (Vite default port)
# For production: add your production frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1:8000

# Application Configuration
APP_NAME=NovaRisk ESG API
APP_ENVIRONMENT=local
LOG_LEVEL=INFO

# Demo Mode - Use mock satellite data when unable to reach Planetary Computer
# Set to 'true' to enable demo mode without requiring network access to Planetary Computer
# Otherwise, falls back automatically when DNS/network errors occur
USE_DEMO_MODE=false

# External API Configuration (if needed for Planetary Computer)
# These are optional as the satellite_processing module handles authentication
PLANETARY_COMPUTER_API_KEY=